{
  "name": "ng-in-action",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test:cov": "ng test --coverage --no-watch && open-cli coverage/ng-in-action/index.html",
    "lint": "ng lint && stylelint \"**/*.scss\" && prettier --check .",
    "lint:fix": "ng lint --fix && stylelint \"**/*.scss\" --fix .src/**/*.scss && prettier --write .",
    "analyze": "ng build --stats-json --named-chunks && open-cli https://esbuild.github.io/analyze"
  },
  "lint-staged": {
    "**/*.{ts,html}": [
      "eslint --fix"
    ],
    "**/*.scss": [
      "stylelint --fix"
    ],
    "**/*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@microsoft/signalr": "^10.0.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "dayjs": "^1.11.20",
    "lit": "^3.3.2",
    "lodash-es": "^4.18.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "@eslint/js": "^10.0.1",
    "@ngrx/eslint-plugin": "^21.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/lodash-es": "^4.17.12",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.3",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.1.5"
  }
}
